'use client';

import { useState, useEffect } from 'react';
import { Line, LineChart, ResponsiveContainer, XAxis, YAxis, Tooltip, Area, AreaChart, PieChart, Pie, Cell } from 'recharts';
import { TrendingUp, Zap, DollarSign, Activity } from 'lucide-react';

// Mock data - replace with real API calls
const generateUsageData = () => {
  const days = 30;
  const data = [];
  let cumulative = 0;

  for (let i = 0; i < days; i++) {
    const calls = Math.floor(Math.random() * 5000) + 2000;
    cumulative += calls;
    data.push({
      day: i + 1,
      calls,
      cumulative,
      limit: 100000,
      cost: calls * 0.0005
    });
  }
  return data;
};

const SUBSCRIPTION_TIER = {
  name: 'Starter',
  price: 29,
  limit: 100000,
  updateFrequency: '1 minute'
};

export default function AnalyticsPage() {
  const [usageData] = useState(generateUsageData());
  const [currentUsage, setCurrentUsage] = useState(0);
  const [projectedUsage, setProjectedUsage] = useState(0);
  const [projectedCost, setProjectedCost] = useState(0);

  useEffect(() => {
    const total = usageData.reduce((sum, day) => sum + day.calls, 0);
    setCurrentUsage(total);

    // Project to end of month
    const daysElapsed = usageData.length;
    const avgPerDay = total / daysElapsed;
    const daysRemaining = 30 - daysElapsed;
    const projected = total + (avgPerDay * daysRemaining);

    setProjectedUsage(Math.floor(projected));

    // Calculate projected cost
    const overage = Math.max(0, projected - SUBSCRIPTION_TIER.limit);
    const overageCost = overage * 0.0005;
    setProjectedCost(SUBSCRIPTION_TIER.price + overageCost);
  }, [usageData]);

  const usagePercent = (currentUsage / SUBSCRIPTION_TIER.limit) * 100;
  const isOverLimit = projectedUsage > SUBSCRIPTION_TIER.limit;

  const costBreakdown = [
    { name: 'Subscription', value: SUBSCRIPTION_TIER.price, color: '#ff006e' },
    { name: 'Overage', value: Math.max(0, projectedCost - SUBSCRIPTION_TIER.price), color: '#ff4d8f' },
  ].filter(item => item.value > 0);

  return (
    <div className="min-h-screen bg-white text-black p-8">
      <div className="max-w-7xl mx-auto">
        {/* Header */}
        <div className="mb-8">
          <h1 className="text-4xl font-bold mb-2">Usage Analytics</h1>
          <p className="text-gray-600">Monitor your oracle usage and costs in real-time</p>
        </div>

        {/* Stats Grid */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
          <div className="border border-gray-200 p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-sm text-gray-600">API Calls</span>
              <Activity size={20} className="text-gray-400" />
            </div>
            <div className="text-3xl font-bold">{currentUsage.toLocaleString()}</div>
            <div className="text-xs text-gray-500 mt-1">
              {usagePercent.toFixed(1)}% of {SUBSCRIPTION_TIER.limit.toLocaleString()}
            </div>
          </div>

          <div className="border border-gray-200 p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-sm text-gray-600">Projected Usage</span>
              <TrendingUp size={20} className="text-gray-400" />
            </div>
            <div className="text-3xl font-bold">{projectedUsage.toLocaleString()}</div>
            <div className={`text-xs mt-1 ${isOverLimit ? 'text-red-600' : 'text-green-600'}`}>
              {isOverLimit ? `${(projectedUsage - SUBSCRIPTION_TIER.limit).toLocaleString()} over limit` : 'Within limit'}
            </div>
          </div>

          <div className="border border-gray-200 p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-sm text-gray-600">Current Bill</span>
              <DollarSign size={20} className="text-gray-400" />
            </div>
            <div className="text-3xl font-bold">${SUBSCRIPTION_TIER.price}</div>
            <div className="text-xs text-gray-500 mt-1">Subscription</div>
          </div>

          <div className="border border-gray-200 p-6">
            <div className="flex items-center justify-between mb-2">
              <span className="text-sm text-gray-600">Projected Bill</span>
              <Zap size={20} className="text-gray-400" />
            </div>
            <div className="text-3xl font-bold">${projectedCost.toFixed(2)}</div>
            <div className={`text-xs mt-1 ${isOverLimit ? 'text-red-600' : 'text-gray-500'}`}>
              {isOverLimit ? `+$${(projectedCost - SUBSCRIPTION_TIER.price).toFixed(2)} overage` : 'No overage'}
            </div>
          </div>
        </div>

        {/* Usage Progress Bar */}
        <div className="mb-8 border border-gray-200 p-6">
          <div className="flex justify-between items-center mb-2">
            <span className="text-sm font-medium">Monthly Usage</span>
            <span className="text-sm text-gray-600">{currentUsage.toLocaleString()} / {SUBSCRIPTION_TIER.limit.toLocaleString()} calls</span>
          </div>
          <div className="w-full bg-gray-200 h-3">
            <div
              className="h-3 transition-all duration-300"
              style={{
                width: `${Math.min(usagePercent, 100)}%`,
                backgroundColor: usagePercent > 90 ? '#ff006e' : usagePercent > 70 ? '#ff8c00' : '#00ff88'
              }}
            />
          </div>
          {usagePercent > 80 && (
            <div className="mt-2 text-xs text-red-600">
              Warning: You've used {usagePercent.toFixed(0)}% of your monthly limit
            </div>
          )}
        </div>

        {/* Charts */}
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
          {/* Usage Trend */}
          <div className="lg:col-span-2 border border-gray-200 p-6">
            <h3 className="text-lg font-bold mb-4">Daily Usage Trend</h3>
            <ResponsiveContainer width="100%" height={300}>
              <AreaChart data={usageData}>
                <defs>
                  <linearGradient id="colorCalls" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor="#ff006e" stopOpacity={0.3}/>
                    <stop offset="95%" stopColor="#ff006e" stopOpacity={0}/>
                  </linearGradient>
                </defs>
                <XAxis
                  dataKey="day"
                  stroke="#666"
                  fontSize={12}
                  tickLine={false}
                  axisLine={false}
                />
                <YAxis
                  stroke="#666"
                  fontSize={12}
                  tickLine={false}
                  axisLine={false}
                  tickFormatter={(value) => `${(value / 1000).toFixed(0)}k`}
                />
                <Tooltip
                  content={({ active, payload }) => {
                    if (active && payload && payload.length) {
                      return (
                        <div className="bg-black border border-gray-800 p-3 text-white text-sm">
                          <p className="font-medium">Day {payload[0].payload.day}</p>
                          <p className="text-gray-400">
                            {payload[0].value?.toLocaleString()} calls
                          </p>
                          <p className="text-gray-400">
                            ${(payload[0].payload.cost).toFixed(2)}
                          </p>
                        </div>
                      );
                    }
                    return null;
                  }}
                />
                <Area
                  type="monotone"
                  dataKey="calls"
                  stroke="#ff006e"
                  strokeWidth={2}
                  fillOpacity={1}
                  fill="url(#colorCalls)"
                />
              </AreaChart>
            </ResponsiveContainer>
          </div>

          {/* Cost Breakdown */}
          <div className="border border-gray-200 p-6">
            <h3 className="text-lg font-bold mb-4">Cost Breakdown</h3>
            <ResponsiveContainer width="100%" height={200}>
              <PieChart>
                <Pie
                  data={costBreakdown}
                  cx="50%"
                  cy="50%"
                  innerRadius={60}
                  outerRadius={80}
                  paddingAngle={5}
                  dataKey="value"
                >
                  {costBreakdown.map((entry, index) => (
                    <Cell key={`cell-${index}`} fill={entry.color} />
                  ))}
                </Pie>
                <Tooltip
                  content={({ active, payload }) => {
                    if (active && payload && payload.length) {
                      return (
                        <div className="bg-black border border-gray-800 p-3 text-white text-sm">
                          <p className="font-medium">{payload[0].name}</p>
                          <p className="text-gray-400">${payload[0].value?.toFixed(2)}</p>
                        </div>
                      );
                    }
                    return null;
                  }}
                />
              </PieChart>
            </ResponsiveContainer>
            <div className="mt-4 space-y-2">
              {costBreakdown.map((item, index) => (
                <div key={index} className="flex justify-between items-center text-sm">
                  <div className="flex items-center">
                    <div
                      className="w-3 h-3 mr-2"
                      style={{ backgroundColor: item.color }}
                    />
                    <span>{item.name}</span>
                  </div>
                  <span className="font-medium">${item.value.toFixed(2)}</span>
                </div>
              ))}
              <div className="pt-2 border-t border-gray-200 flex justify-between font-bold">
                <span>Total</span>
                <span>${projectedCost.toFixed(2)}</span>
              </div>
            </div>
          </div>
        </div>

        {/* Cumulative Usage */}
        <div className="border border-gray-200 p-6 mb-8">
          <h3 className="text-lg font-bold mb-4">Cumulative Usage vs Limit</h3>
          <ResponsiveContainer width="100%" height={300}>
            <LineChart data={usageData}>
              <XAxis
                dataKey="day"
                stroke="#666"
                fontSize={12}
                tickLine={false}
                axisLine={false}
              />
              <YAxis
                stroke="#666"
                fontSize={12}
                tickLine={false}
                axisLine={false}
                tickFormatter={(value) => `${(value / 1000).toFixed(0)}k`}
              />
              <Tooltip
                content={({ active, payload }) => {
                  if (active && payload && payload.length) {
                    return (
                      <div className="bg-black border border-gray-800 p-3 text-white text-sm">
                        <p className="font-medium">Day {payload[0].payload.day}</p>
                        <p className="text-gray-400">
                          Total: {payload[0].value?.toLocaleString()} calls
                        </p>
                        <p className="text-gray-400">
                          Limit: {SUBSCRIPTION_TIER.limit.toLocaleString()}
                        </p>
                      </div>
                    );
                  }
                  return null;
                }}
              />
              <Line
                type="monotone"
                dataKey="cumulative"
                stroke="#ff006e"
                strokeWidth={2}
                dot={false}
              />
              <Line
                type="monotone"
                dataKey="limit"
                stroke="#666"
                strokeWidth={2}
                strokeDasharray="5 5"
                dot={false}
              />
            </LineChart>
          </ResponsiveContainer>
        </div>

        {/* Subscription Details */}
        <div className="border border-gray-200 p-6">
          <h3 className="text-lg font-bold mb-4">Current Plan: {SUBSCRIPTION_TIER.name}</h3>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <div className="text-sm text-gray-600 mb-1">Monthly Cost</div>
              <div className="text-2xl font-bold">${SUBSCRIPTION_TIER.price}</div>
            </div>
            <div>
              <div className="text-sm text-gray-600 mb-1">API Call Limit</div>
              <div className="text-2xl font-bold">{SUBSCRIPTION_TIER.limit.toLocaleString()}</div>
            </div>
            <div>
              <div className="text-sm text-gray-600 mb-1">Update Frequency</div>
              <div className="text-2xl font-bold">{SUBSCRIPTION_TIER.updateFrequency}</div>
            </div>
          </div>
          <div className="mt-6 flex gap-4">
            <button className="px-6 py-2 bg-black text-white hover:bg-gray-800 transition-colors">
              Upgrade Plan
            </button>
            <button className="px-6 py-2 border border-gray-300 hover:bg-gray-50 transition-colors">
              View Billing
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}
